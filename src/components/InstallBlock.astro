---
interface Props {
  command: string;
  label?: string;
}
const { command, label } = Astro.props;
---
<div class="my-4">
  {label && <div class="text-xs text-zinc-500 mb-1">{label}</div>}
  <pre class="bg-zinc-900 text-zinc-100 px-4 py-3 rounded font-mono text-sm overflow-x-auto"><code>{command}</code></pre>
</div>
