---
import type { CollectionEntry } from 'astro:content';
import ToolCard from './ToolCard.astro';

interface Props {
  title: string;
  kind: 'skill' | 'tool' | 'harness';
  tools: CollectionEntry<'tools'>[];
}
const { title, kind, tools } = Astro.props;
const filtered = tools.filter((t) => t.data.kind === kind);
---
{filtered.length > 0 && (
  <section class="mt-12">
    <h2 class="text-xl font-semibold mb-4">{title}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {filtered.map((t) => <ToolCard tool={t} />)}
    </div>
  </section>
)}
