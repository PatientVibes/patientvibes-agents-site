---
import type { CollectionEntry } from 'astro:content';

interface Props {
  tool: CollectionEntry<'tools'>;
}
const { tool } = Astro.props;
const { slug, name, kind, status, shortDescription } = tool.data;
---
<a href={`/tools/${slug}/`} class="block border border-zinc-200 rounded-lg p-4 hover:border-zinc-400 hover:shadow-sm transition">
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-mono text-sm font-semibold">{name}</h3>
    <span class="text-xs px-2 py-0.5 rounded bg-zinc-100 text-zinc-600 font-mono">{status}</span>
  </div>
  <p class="text-sm text-zinc-600 mt-2 line-clamp-3">{shortDescription}</p>
  <div class="text-xs text-zinc-400 mt-3 font-mono uppercase tracking-wide">{kind}</div>
</a>
