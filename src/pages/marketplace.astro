---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstallBlock from '../components/InstallBlock.astro';
---
<BaseLayout title="Skills marketplace" description="Install the patientvibes-skills marketplace in Claude Code.">
  <h1 class="text-3xl font-bold">Skills marketplace</h1>
  <p class="text-zinc-600 mt-2">
    The <code class="font-mono px-1 bg-zinc-100">patientvibes-skills</code> marketplace publishes Claude Code plugins
    (skills, agents, hooks). It's hosted at
    <a href="https://github.com/PatientVibes/agent-skills" class="underline">github.com/PatientVibes/agent-skills</a>.
  </p>

  <h2 class="text-xl font-semibold mt-10">Install in Claude Code</h2>
  <ol class="list-decimal pl-6 mt-4 space-y-3 text-zinc-700">
    <li>
      Add the marketplace:
      <InstallBlock command="/plugin marketplace add github:PatientVibes/agent-skills" />
    </li>
    <li>
      Install a plugin:
      <InstallBlock command="/plugin install pr-review-tools@patientvibes-skills" />
    </li>
    <li>
      List installed plugins to confirm:
      <InstallBlock command="/plugin list" />
    </li>
  </ol>

  <h2 class="text-xl font-semibold mt-10">Currently published</h2>
  <ul class="mt-4 space-y-2 text-sm">
    <li>
      <code class="font-mono">pr-review-tools</code> — AI-driven PR review skill.
      <a href="/tools/agent-skills/" class="underline ml-2">Details ↗</a>
    </li>
  </ul>

  <p class="text-sm text-zinc-500 mt-12">
    Source: <a href="https://github.com/PatientVibes/agent-skills" class="underline">github.com/PatientVibes/agent-skills</a>
  </p>
</BaseLayout>
